{
  "name": "rebro-qr-generator",
  "version": "1.0.0",
  "private": true,
  "description": "Chrome extension to generate Rebro QR codes from Booth item pages",
  "scripts": {
    "build": "esbuild src/content.js --bundle --outfile=dist/content.js --format=iife",
    "watch": "esbuild src/content.js --bundle --outfile=dist/content.js --format=iife --watch"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
