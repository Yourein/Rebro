{
  "manifest_version": 3,
  "name": "Rebro QR Generator",
  "version": "1.0.0",
  "description": "Boothの商品ページからRebro用のQRコードを生成します",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://*.booth.pm/items/*",
        "https://www.melonbooks.co.jp/detail/detail.php*"
      ],
      "js": ["dist/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
